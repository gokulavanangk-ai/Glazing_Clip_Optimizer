# =============================================================================
# MERN Stack .gitignore
# Covers: Root / Frontend (React) / Backend (Node.js + Express)
# =============================================================================


# =============================================================================
# DEPENDENCIES
# =============================================================================

# Root
node_modules/

# Backend
backend/node_modules/

# Frontend
frontend/node_modules/


# =============================================================================
# ENVIRONMENT VARIABLES & SECRETS
# =============================================================================

.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging

# Backend env files
backend/.env
backend/.env.*

# Frontend env files
frontend/.env
frontend/.env.*

# Secret keys, certificates, and credentials
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
secrets/
config/secrets.js
config/secrets.json


# =============================================================================
# BUILD & DIST OUTPUT
# =============================================================================

# React production build
frontend/build/
frontend/dist/

# Backend compiled output (if using TypeScript or Babel)
backend/build/
backend/dist/

# Root-level build artifacts
build/
dist/


# =============================================================================
# LOGS & DEBUG
# =============================================================================

logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Backend-specific logs
backend/logs/
backend/*.log

# Runtime crash reports
crash.log
crash.*.log


# =============================================================================
# RUNTIME & CACHE
# =============================================================================

# npm / yarn / pnpm caches
.npm/
.yarn/
.pnp
.pnp.js
.cache/

# Parcel cache
.parcel-cache/

# Next.js (if applicable)
.next/
out/

# Vite cache
.vite/

# eslint / stylelint cache
.eslintcache
.stylelintcache

# TypeScript incremental compilation info
*.tsbuildinfo

# Optional: React Native (if ever extended)
.expo/
.expo-shared/


# =============================================================================
# TESTING & COVERAGE
# =============================================================================

coverage/
.nyc_output/
frontend/coverage/
backend/coverage/


# =============================================================================
# DATABASE & LOCAL DATA
# =============================================================================

# Local SQLite or embedded DB files
*.sqlite
*.sqlite3
*.db

# MongoDB local data directory (if running locally)
data/db/

# Seed output or dump files
*.dump
*.sql
dump.rdb


# =============================================================================
# OS-SPECIFIC FILES
# =============================================================================

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# Windows
Thumbs.db
Thumbs.db:encryptable
desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~


# =============================================================================
# IDE & EDITOR CONFIGS
# =============================================================================

# VS Code
.vscode/
!.vscode/extensions.json    # Allow sharing recommended extensions

# JetBrains (WebStorm, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-workspace
*.sublime-project

# Vim / Neovim
*.swp
*.swo
*.swn
Session.vim
.netrwhist

# Emacs
\#*\#
.\#*


# =============================================================================
# DOCKER & DEPLOYMENT (local overrides only)
# =============================================================================

# Local docker-compose overrides — keep the base file tracked
docker-compose.override.yml

# Terraform state (if used)
*.tfstate
*.tfstate.*
.terraform/


# =============================================================================
# MISCELLANEOUS
# =============================================================================

# Compressed archives
*.zip
*.tar.gz
*.rar
*.7z

# Generated documentation
docs/_build/

# Storybook build output
storybook-static/

# Serverless framework
.serverless/

# =============================================================================
# EXPLICITLY NOT IGNORED (tracked intentionally)
# — package.json
# — package-lock.json
# — yarn.lock / pnpm-lock.yaml
# =============================================================================
